---
interface Props {
  eyebrow?: string;
  title: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, align = 'left' } = Astro.props;
---

<div class:list={['flex flex-col gap-2', align === 'center' && 'items-center text-center']}>
  {
    eyebrow && (
      <span class="inline-flex items-center gap-1.5 text-[13px] font-bold uppercase tracking-wider text-accent-500">
        <span class="h-1 w-1 rounded-full bg-accent-500" aria-hidden="true" />
        {eyebrow}
      </span>
    )
  }
  <h2 class="font-display text-[26px] font-bold leading-tight tracking-tight text-ink sm:text-[30px]">
    {title}
  </h2>
</div>
