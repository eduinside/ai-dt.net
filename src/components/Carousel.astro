---
/**
 * 캐러셀 — CSS scroll-snap 기반. 모바일 스와이프 자연 지원, JS는 점 표시/이동만(경량).
 * MDX: <Carousel images={[{ src, alt }, ...]} />
 */
interface Slide {
  src: string;
  alt?: string;
  caption?: string;
}
interface Props {
  images: Slide[];
}
const { images } = Astro.props;
const uid = 'car-' + Math.random().toString(36).slice(2, 8);
---

<div class="carousel not-prose relative group/carousel" data-carousel data-uid={uid}>
  {
    images.length > 1 && (
      <>
        <button
          type="button"
          class="absolute left-4 top-1/2 -translate-y-1/2 z-10 flex h-10 w-10 items-center justify-center rounded-full border border-line bg-white/90 text-ink shadow-sm transition-all hover:bg-white hover:scale-105 active:scale-95 opacity-0 group-hover/carousel:opacity-100 focus:opacity-100 cursor-pointer"
          data-prev-btn
          aria-label="이전 슬라이드"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button
          type="button"
          class="absolute right-4 top-1/2 -translate-y-1/2 z-10 flex h-10 w-10 items-center justify-center rounded-full border border-line bg-white/90 text-ink shadow-sm transition-all hover:bg-white hover:scale-105 active:scale-95 opacity-0 group-hover/carousel:opacity-100 focus:opacity-100 cursor-pointer"
          data-next-btn
          aria-label="다음 슬라이드"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </>
    )
  }

  <div
    class="scroll-track flex snap-x snap-mandatory gap-0 overflow-x-auto scroll-smooth rounded-2xl [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]"
    role="group"
    aria-roledescription="캐러셀"
    tabindex="0"
  >
    {
      images.map((img, i) => (
        <figure class="relative w-full shrink-0 snap-center" data-slide>
          <img
            src={img.src}
            alt={img.alt ?? `슬라이드 ${i + 1}`}
            loading={i === 0 ? 'eager' : 'lazy'}
            class="w-full h-auto rounded-2xl border border-line object-contain"
          />
          {img.caption && (
            <figcaption class="absolute inset-x-0 bottom-0 rounded-b-2xl bg-gradient-to-t from-ink/70 to-transparent px-4 py-3 text-sm text-white">
              {img.caption}
            </figcaption>
          )}
        </figure>
      ))
    }
  </div>

  {
    images.length > 1 && (
      <div class="mt-3 flex items-center justify-center gap-2" data-dots>
        {images.map((_, i) => (
          <button
            type="button"
            class="h-2 w-2 rounded-full bg-line transition-all data-[active]:w-5 data-[active]:bg-primary-500"
            data-dot
            data-index={i}
            aria-label={`${i + 1}번 슬라이드로 이동`}
          />
        ))}
      </div>
    )
  }
</div>

<script>
  function initCarousels() {
    document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((root) => {
      if (root.dataset.init) return;
      root.dataset.init = '1';
      const track = root.querySelector<HTMLElement>('.scroll-track')!;
      const slides = Array.from(root.querySelectorAll<HTMLElement>('[data-slide]'));
      const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-dot]'));
      if (!slides.length) return;

      let currentIdx = 0;

      const setActive = (idx: number) => {
        currentIdx = idx;
        dots.forEach((d, i) =>
          i === idx ? d.setAttribute('data-active', '') : d.removeAttribute('data-active')
        );
      };
      setActive(0);

      dots.forEach((dot) =>
        dot.addEventListener('click', () => {
          const i = Number(dot.dataset.index);
          slides[i]?.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
        })
      );

      // 좌우 버튼 바인딩
      const prevBtn = root.querySelector<HTMLButtonElement>('[data-prev-btn]');
      const nextBtn = root.querySelector<HTMLButtonElement>('[data-next-btn]');

      prevBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        const targetIdx = (currentIdx - 1 + slides.length) % slides.length;
        slides[targetIdx]?.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      });

      nextBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        const targetIdx = (currentIdx + 1) % slides.length;
        slides[targetIdx]?.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      });

      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) setActive(slides.indexOf(e.target as HTMLElement));
          });
        },
        { root: track, threshold: 0.6 }
      );
      slides.forEach((s) => io.observe(s));
    });
  }
  initCarousels();
  document.addEventListener('astro:page-load', initCarousels);
</script>
