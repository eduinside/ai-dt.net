---
interface Props {
  href: string;
  variant?: 'primary' | 'ghost' | 'ghost-dark';
  external?: boolean;
  class?: string;
}
const { href, variant = 'primary', external = false, class: cls = '' } = Astro.props;

// 원본 버튼 톤: 다크 슬레이트 채움 / 흰 바탕 아웃라인 (사각형에 가까운 라운드)
const styles: Record<string, string> = {
  primary: 'bg-primary-600 text-white hover:bg-primary-700 shadow-sm',
  ghost: 'bg-white text-ink border border-line hover:border-primary-400 hover:text-primary-600',
  'ghost-dark': 'bg-white text-ink hover:bg-primary-50',
};
const ext = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<a
  href={href}
  {...ext}
  class:list={[
    'inline-flex items-center justify-center gap-1.5 rounded-[4px] px-5 py-2.5 text-[14px] font-semibold transition-all active:scale-[0.99]',
    styles[variant],
    cls,
  ]}
>
  <slot />
  {
    external && (
      <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M3 11L11 3M5 3h6v6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    )
  }
</a>
