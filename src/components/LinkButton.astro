---
interface Props {
  href: string;
  variant?: 'primary' | 'accent' | 'ghost';
  external?: boolean;
  class?: string;
}
const { href, variant = 'primary', external = false, class: cls = '' } = Astro.props;

const styles: Record<string, string> = {
  primary: 'bg-primary-600 text-white hover:bg-primary-700 shadow-sm',
  accent: 'bg-accent-500 text-white hover:bg-accent-600 shadow-sm',
  ghost: 'bg-surface text-ink border border-line hover:border-primary-400 hover:text-primary-700',
};
const ext = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<a
  href={href}
  {...ext}
  class:list={[
    'inline-flex items-center justify-center gap-1.5 rounded-full px-5 py-2.5 text-[15px] font-semibold transition-all active:scale-[0.98]',
    styles[variant],
    cls,
  ]}
>
  <slot />
  {
    external && (
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M3 11L11 3M5 3h6v6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    )
  }
</a>
