---
interface Props {
  href: string;
  variant?: 'primary' | 'ghost' | 'ghost-dark';
  external?: boolean;
  class?: string;
}
const { href, variant = 'primary', external = false, class: cls = '' } = Astro.props;

// 버튼 톤: 딥 네이비 채움 / 흰 바탕 아웃라인
const baseStyles: Record<string, string> = {
  primary: 'bg-primary-600 text-white hover:bg-primary-700 shadow-sm border border-transparent',
  ghost: 'bg-white text-ink border hover:bg-primary-50 hover:text-primary-600',
  'ghost-dark': 'bg-white text-primary-700 hover:bg-primary-50 border border-transparent',
};
const externalStyle = external ? 'border-primary-400 text-primary-700 shadow-sm bg-primary-50/30' : 'border-line';
const ext = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<a
  href={href}
  {...ext}
  class:list={[
    'inline-flex items-center justify-center gap-1.5 rounded-lg px-5 py-2.5 text-[14px] font-semibold transition-all active:scale-[0.99]',
    baseStyles[variant],
    variant === 'ghost' ? externalStyle : '',
    cls,
  ]}
>
  <slot />
  {
    external && (
      <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M3 11L11 3M5 3h6v6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    )
  }
</a>
