---
/**
 * 원본 푸터 — 연락처 4건 2열 (docs/original/CONTENT.md §2)
 */
const contacts = [
  { label: '[AI·디지털 교육자료 포털]', value: '중앙상담센터 1600-2525' },
  { label: '[회원가입 관련]', value: '교육디지털원패스 1600-7440' },
  { label: '[발행사 문의]', value: '한국교과서협회(KTA) 1661-0777' },
  {
    label: '[학교 디지털인프라 관련]',
    value: '053-235-9999',
    link: { href: 'https://tech.dge.go.kr/', text: '대구광역시교육청 테크센터' },
  },
];
---

<footer class="mt-20 border-t border-line bg-white">
  <div class="mx-auto max-w-6xl px-5 py-10">
    <dl class="grid gap-x-12 gap-y-3 text-[15px] sm:grid-cols-2">
      {
        contacts.map((c) => (
          <div class="flex flex-wrap items-baseline gap-x-1.5">
            <dt class="font-semibold text-ink">{c.label}</dt>
            <dd class="text-ink">
              {c.link && (
                <a
                  href={c.link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="underline underline-offset-2 hover:text-primary-500"
                >
                  {c.link.text}
                </a>
              )}{c.link ? ' ' : ''}{c.value}
            </dd>
          </div>
        ))
      }
    </dl>

    <div class="mt-8 border-t border-line pt-5 text-[13px] text-muted">
      https://www.ai-dt.net · 대구광역시교육청 AI·디지털 교육자료 수업 지원센터
    </div>
  </div>
</footer>
