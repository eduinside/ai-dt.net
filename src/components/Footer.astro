---
/**
 * 원본 푸터 — 연락처 4건 2열 (docs/original/CONTENT.md §2)
 * 다크 네이비 마감 — 페이지 하단의 시각적 종결부.
 */
import { Image } from 'astro:assets';
import logo from '../assets/logo-512.webp';

const contacts = [
  { label: '[AI·디지털 교육자료 포털]', value: '중앙상담센터 1600-2525' },
  { label: '[회원가입 관련]', value: '교육디지털원패스 1600-7440' },
  { label: '[발행사 문의]', value: '한국교과서협회(KTA) 1661-0777' },
  {
    label: '[학교 디지털인프라 관련]',
    value: '053-235-9999',
    link: { href: 'https://tech.dge.go.kr/', text: '대구광역시교육청 테크센터' },
  },
];
---

<footer class="mt-20 bg-primary-800 text-white">
  <div class="mx-auto max-w-6xl px-5 py-12">
    <div class="flex items-center justify-between gap-4">
      <p class="text-[15px] font-bold tracking-tight">AI·디지털 교육자료 수업 지원센터</p>
      <Image src={logo} alt="대구광역시교육청" width={128} height={128} class="h-16 w-16 shrink-0" loading="lazy" />
    </div>

    <dl class="mt-6 grid gap-x-12 gap-y-4 text-[14.5px] sm:grid-cols-2">
      {
        contacts.map((c) => (
          <div>
            <dt class="font-semibold text-primary-200">{c.label}</dt>
            <dd class="mt-0.5 text-white/90">
              {c.link && (
                <a
                  href={c.link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="underline underline-offset-2 transition-colors hover:text-white"
                >
                  {c.link.text}
                </a>
              )}{c.link ? ' ' : ''}{c.value}
            </dd>
          </div>
        ))
      }
    </dl>

    <div
      class="mt-10 flex flex-wrap items-center justify-between gap-4 border-t border-white/15 pt-5 text-[13px] text-primary-200"
    >
      <div>https://www.ai-dt.net · 대구광역시교육청 AI·디지털 교육자료 수업 지원센터</div>
      <div>
        <a href="/sitemap" class="underline underline-offset-2 transition-colors hover:text-white">사이트맵</a>
      </div>
    </div>
  </div>
</footer>
