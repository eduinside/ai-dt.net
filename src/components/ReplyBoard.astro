---
/**
 * 출판사 회신 QnA형 게시판 — 목록형 행(row) + 펼치면 회신 문서 이미지.
 * 이미지는 src/assets/replies/{slug}/{dir}/*.png (원본 구글 사이트에서 이관, =w1280).
 * <details> 기반이라 JS 0줄, 이미지 자체는 lazy 로드.
 */
import { Image } from 'astro:assets';

interface Row {
  slug: string;      // 자료 폴더 (예: cheonjae, faq)
  publisher: string; // 표시 이름 (예: 천재)
  label: string;     // 학교급·교과 또는 FAQ 제목
  dir: string;       // 이미지 폴더 번호 (예: "01")
  date?: string;     // 게시일 (FAQ 등)
}
interface Props {
  rows: Row[];
  showPublisher?: boolean; // 허브(전체 목록)에서 출판사 배지 표시
}
const { rows, showPublisher = true } = Astro.props;

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/replies/**/*.png',
  { eager: true }
);
const imagesFor = (slug: string, dir: string) =>
  Object.entries(allImages)
    .filter(([path]) => path.includes(`/replies/${slug}/${dir}/`))
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([, mod]) => mod.default);
---

<div class="divide-y divide-line border-y border-line">
  {
    rows.map((row) => {
      const imgs = imagesFor(row.slug, row.dir);
      return (
        <details class="group" id={`${row.slug}-${row.dir}`}>
          <summary class="flex cursor-pointer list-none items-center gap-3 px-2 py-4 transition-colors hover:bg-primary-50/60">
            {showPublisher && (
              <span class="shrink-0 rounded-[4px] bg-primary-600 px-2.5 py-1 text-[13px] font-semibold text-white">
                {row.publisher}
              </span>
            )}
            <span class="min-w-0 flex-1 truncate text-left text-[15px] font-semibold text-ink">
              {row.label}
            </span>
            {row.date && (
              <span class="hidden shrink-0 text-[13px] text-muted sm:inline">
                {row.date.replaceAll('-', '.')}
              </span>
            )}
            <span class="shrink-0 text-[13px] text-muted">
              문서 {imgs.length}장
            </span>
            <svg
              width="14"
              height="14"
              viewBox="0 0 14 14"
              fill="none"
              aria-hidden="true"
              class="shrink-0 text-muted transition-transform duration-200 group-open:rotate-180"
            >
              <path d="M2 5l5 5 5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </summary>
          <div class="space-y-4 bg-primary-50/40 px-2 py-5 sm:px-5">
            {imgs.length === 0 && (
              <p class="text-[14px] text-muted">회신 문서를 이관 중입니다.</p>
            )}
            {imgs.map((img, i) => (
              <Image
                src={img}
                alt={`${showPublisher ? `'${row.publisher}' ` : ''}${row.label} 문서 ${i + 1}쪽`}
                widths={[720, 1280]}
                sizes="(max-width: 768px) 100vw, 720px"
                class="mx-auto w-full max-w-[720px] rounded-md border border-line bg-white shadow-[var(--shadow-card)]"
                loading="lazy"
              />
            ))}
          </div>
        </details>
      );
    })
  }
</div>

<style>
  summary::-webkit-details-marker {
    display: none;
  }
</style>
