---
interface Props {
  href: string;
  name: string;
  subjects: string[];
  accent?: string;
  draft?: boolean;
}
const { href, name, subjects, accent = '#0f7d84', draft = false } = Astro.props;
// 이름 첫 글자를 이니셜 마크로
const initial = name.trim().charAt(0);
---

<a
  href={href}
  class="group relative flex flex-col overflow-hidden rounded-[var(--radius-card)] border border-line bg-surface p-5 shadow-[var(--shadow-card)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[var(--shadow-card-hover)]"
>
  <span
    class="absolute inset-x-0 top-0 h-1 origin-left scale-x-0 transition-transform duration-300 group-hover:scale-x-100"
    style={`background:${accent}`}
    aria-hidden="true"
  ></span>

  <div class="flex items-center gap-3">
    <span
      class="grid h-11 w-11 shrink-0 place-items-center rounded-xl font-display text-lg font-bold text-white"
      style={`background:${accent}`}
      aria-hidden="true"
    >
      {initial}
    </span>
    <div class="min-w-0">
      <h3 class="truncate font-display text-[17px] font-bold text-ink">{name}</h3>
      <p class="truncate text-[13px] text-muted">{subjects.join(' · ') || 'AI 디지털교과서'}</p>
    </div>
  </div>

  <div class="mt-4 flex items-center justify-between">
    {
      draft ? (
        <span class="rounded-full bg-line/60 px-2.5 py-1 text-[12px] font-medium text-muted">준비 중</span>
      ) : (
        <span class="rounded-full bg-primary-50 px-2.5 py-1 text-[12px] font-medium text-primary-700">도움자료 있음</span>
      )
    }
    <span
      class="flex items-center gap-1 text-[13px] font-semibold text-muted transition-colors group-hover:text-primary-700"
      aria-hidden="true"
    >
      바로가기
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="transition-transform group-hover:translate-x-0.5">
        <path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </span>
  </div>
</a>
