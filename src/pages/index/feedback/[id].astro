---
/**
 * 출판사 상세 — 원본 제목 패턴('{이름}' 회신 내용) + 해당 출판사만 필터된 목록형 게시판.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ReplyBoard from '../../../components/ReplyBoard.astro';

export async function getStaticPaths() {
  const publishers = await getCollection('publishers');
  return publishers.map((p) => ({ params: { id: p.id }, props: { entry: p } }));
}

const { entry } = Astro.props;
const { data } = entry;

const publishers = (await getCollection('publishers')).sort(
  (a, b) => a.data.order - b.data.order
);

const rows = data.sections.map((s) => ({
  slug: entry.id,
  publisher: data.name,
  label: s.label,
  dir: s.dir,
}));
---

<BaseLayout
  title={data.name}
  description={`'${data.name}' AI·디지털 교육자료 개선 요청 회신 내용`}
>
  <section class="mx-auto max-w-4xl px-5 py-12 sm:py-14">
    <h1 class="title-underline text-center text-[24px] font-bold leading-tight text-ink sm:text-[30px]">
      '{data.name}' 회신 내용
    </h1>

    <!-- 출판사 필터 칩 -->
    <nav class="mt-8 flex flex-wrap justify-center gap-2" aria-label="출판사 필터">
      <a
        href="/index/feedback/"
        class="rounded-full border border-line bg-white px-3.5 py-1.5 text-[13px] font-medium text-ink transition-colors hover:border-primary-400 hover:text-primary-600"
      >
        전체
      </a>
      {
        publishers.map((p) =>
          p.id === entry.id ? (
            <span class="rounded-full bg-primary-600 px-3.5 py-1.5 text-[13px] font-semibold text-white" aria-current="page">
              {p.data.name}
            </span>
          ) : (
            <a
              href={`/index/feedback/${p.id}/`}
              class="rounded-full border border-line bg-white px-3.5 py-1.5 text-[13px] font-medium text-ink transition-colors hover:border-primary-400 hover:text-primary-600"
            >
              {p.data.name}
            </a>
          )
        )
      }
    </nav>

    <div class="mt-8">
      <ReplyBoard rows={rows} showPublisher={false} />
    </div>

    <div class="mt-12 text-center">
      <a
        href="/index/feedback/"
        class="inline-flex items-center gap-1 text-[15px] font-semibold text-ink underline underline-offset-4 hover:text-primary-500"
      >
        ◀ 돌아가기
      </a>
    </div>
  </section>
</BaseLayout>
