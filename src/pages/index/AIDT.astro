---
/**
 * AI·디지털 교육자료 활용 도움자료 — 원본(docs/original/CONTENT.md §4).
 */
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LinkButton from "../../components/LinkButton.astro";
import PageNavigation from "../../components/PageNavigation.astro";

import imgGuide11 from "../../assets/pages/manual/11.png";
import imgGuide12 from "../../assets/pages/manual/12.png";

const cards = [
  {
    title: "AI·디지털 교육자료 포털", href: "https://www.aidtbook.kr/index.do",
  },
  { title: "AI·디지털 교육자료 웹전시관", href: "https://aidtshow.kr/" },
];

const moeDocs = [
  {
    label: "FAQ 모음(2025)",
    href: "https://drive.google.com/file/d/1wNKrj2p4mUO0uaq_ZU9nteewIxaKZbP_/view",
  },
  {
    label: "AI 디지털교과서 준비(2025)",
    href: "https://drive.google.com/file/d/1mUZ49TBxH63vriMFG5jlKhfe05RXT_It/view",
  },
  {
    label: "AI 디지털교과서 활용(2025)",
    href: "https://drive.google.com/file/d/1vN89EsTm9O2sxX0FQFJ6PhyIqFyTFg-p/view",
  },
];
const dgeDocs = [
  {
    label:
      "붙임1. 교육디지털원패스 및 AI·디지털교육자료 포털 안내(이용동의 및 로그인).pdf",
    href: "https://drive.google.com/file/d/1rYC2dRXC5orKS-MlrZ0eHPV56ozRmKQI/view",
  },
  {
    label: "붙임3_AI·디지털 교육자료 이용 준비 퀵가이드.pdf",
    href: "https://drive.google.com/file/d/1jOjOYVLc6FTi19zMc_4CFMzsmOxrxgQ4/view",
  },
  {
    label: "붙임4_[교사] AI·디지털 교육자료 포털 서비스 이용 준비.pdf",
    href: "https://drive.google.com/file/d/1asrRTpB4UdmjwsY0vUqsgPS8Ba9Oi9Gn/view",
  },
  {
    label: "붙임4-1 [초등] AI·디지털 교육자료 이용을 위한 나이스 준비사항.pdf",
    href: "https://drive.google.com/file/d/1JB2ykvCiEJl-LT4YZMA20_TqVPY0gvhp/view",
  },
  {
    label: "붙임4-2 [중등] AI·디지털 교육자료 이용을 위한 나이스 준비사항.pdf",
    href: "https://drive.google.com/file/d/1s6NpvO8S-T7FFPk3tt8rlaXGVkuamh_v/view",
  },
  {
    label: "붙임5_[학생] AI·디지털 교육자료 포털 서비스 이용 준비.pdf",
    href: "https://drive.google.com/file/d/17wQGtOMtdm5cWR8snjARu04hBXJ4mQny/view",
  },
];
const forms = [
  {
    label: "편집 가능 서식(Canva)",
    href: "https://www.canva.com/design/DAGmKaC0BzU/kehQ-qNuicw8iWf11czrEA/view",
  },
  {
    label: "웹포스터(PDF)",
    href: "https://drive.google.com/file/d/1Bu01VtbzCK9F31OEA9nEJFtm0-TVEyYm/view",
  },
  {
    label: "가정통신문(HWP)",
    href: "https://drive.google.com/file/d/1cFZeSVh8JctirODhmfWOS-R3wqvMcQHO/view",
  },
];
---

<BaseLayout
  title="AI·디지털 교육자료 활용 도움자료"
  description="AI·디지털 교육자료 포털·웹전시관과 대구교육청 활용 도움자료 안내"
>
  <section class="mx-auto max-w-3xl px-5 py-12 sm:py-14">
    <h1
      class="title-underline text-center text-[24px] font-bold leading-tight text-ink sm:text-[30px]"
    >
      AI·디지털 교육자료 활용 도움자료
    </h1>

    <div class="mt-10 space-y-4">
      {
        cards.map((c) => (
          <div class="flex flex-wrap items-center justify-between gap-3 rounded-[var(--radius-card)] border border-line bg-white p-5 shadow-[var(--shadow-card)]">
            <p class="text-[16px] font-semibold text-ink">{c.title} →</p>
            <LinkButton href={c.href} variant="primary" external>
              바로가기
            </LinkButton>
          </div>
        ))
      }
    </div>

    <!-- 활용 도움자료(교육부) -->
    <div class="mt-10 space-y-4">
      <h2 class="text-[18px] font-bold text-ink">활용 도움자료 (교육부)</h2>
      <div class="grid gap-3 grid-cols-1 sm:grid-cols-2">
        {
          moeDocs.map((d) => (
            <a
              href={d.href}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-between gap-2 rounded-[var(--radius-card)] border border-line bg-white px-4 py-3 text-[14px] font-semibold text-ink shadow-[var(--shadow-card)] transition-colors hover:border-primary-400 hover:text-primary-600"
            >
              {d.label}
              <svg
                width="13"
                height="13"
                viewBox="0 0 14 14"
                fill="none"
                aria-hidden="true"
                class="shrink-0 text-muted"
              >
                <path
                  d="M3 11L11 3M5 3h6v6"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          ))
        }
      </div>
    </div>

    <!-- 활용 도움자료(대구교육청) -->
    <div class="mt-10 space-y-4">
      <h2 class="text-[18px] font-bold text-ink">활용 도움자료 (대구교육청)</h2>
      <div class="grid gap-3 grid-cols-1 sm:grid-cols-2">
        {
          dgeDocs.map((d) => (
            <a
              href={d.href}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-between gap-2 rounded-[var(--radius-card)] border border-line bg-white px-4 py-3 text-[14px] font-semibold text-ink shadow-[var(--shadow-card)] transition-colors hover:border-primary-400 hover:text-primary-600"
            >
              <span class="break-all">{d.label}</span>
              <svg
                width="13"
                height="13"
                viewBox="0 0 14 14"
                fill="none"
                aria-hidden="true"
                class="shrink-0 text-muted"
              >
                <path
                  d="M3 11L11 3M5 3h6v6"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          ))
        }
      </div>
    </div>

    <!-- AI·디지털 교육자료 활용 안내장(2025)(대구교육청) -->
    <div class="mt-10 space-y-4">
      <h2 class="text-[18px] font-bold text-ink">
        AI·디지털 교육자료 활용 안내장 (2025, 대구교육청)
      </h2>
      <div class="grid gap-3 grid-cols-1 sm:grid-cols-2">
        {
          forms.map((f) => (
            <a
              href={f.href}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-between gap-2 rounded-[var(--radius-card)] border border-line bg-white px-4 py-3 text-[14px] font-semibold text-ink shadow-[var(--shadow-card)] transition-colors hover:border-primary-400 hover:text-primary-600"
            >
              {f.label}
              <svg
                width="13"
                height="13"
                viewBox="0 0 14 14"
                fill="none"
                aria-hidden="true"
                class="shrink-0 text-muted"
              >
                <path
                  d="M3 11L11 3M5 3h6v6"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          ))
        }
      </div>
      <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <button class="w-full block outline-none focus:ring-4 focus:ring-primary-500 rounded-lg transition-transform hover:opacity-95 cursor-zoom-in lightbox-trigger" data-img-src={imgGuide11.src} aria-label="안내장 11 크게 보기">
          <Image src={imgGuide11} alt="안내장 11" class="w-full h-auto rounded-lg border border-line shadow-sm" />
        </button>
        <button class="w-full block outline-none focus:ring-4 focus:ring-primary-500 rounded-lg transition-transform hover:opacity-95 cursor-zoom-in lightbox-trigger" data-img-src={imgGuide12.src} aria-label="안내장 12 크게 보기">
          <Image src={imgGuide12} alt="안내장 12" class="w-full h-auto rounded-lg border border-line shadow-sm" />
        </button>
      </div>
    </div>

    <PageNavigation
      prev={{ title: "사전 준비사항 안내", href: "/index/manual" }}
      next={{ title: "교육디지털원패스", href: "/index/eduonepass" }}
    />
  </section>

  <!-- Lightbox Dialog -->
  <dialog id="lightbox" class="fixed inset-0 z-50 w-full h-full max-w-none bg-black/80 backdrop-blur-sm p-4 m-0 flex-col items-center justify-center opacity-0 transition-opacity duration-300 open:flex open:opacity-100 cursor-zoom-out" aria-modal="true">
    <div class="relative w-full max-w-[95vw] max-h-[95vh] overflow-auto hide-scrollbar text-center flex items-center justify-center">
      <img id="lightbox-img" src="" alt="크게 보기" class="max-w-full max-h-[90vh] object-contain cursor-default bg-white rounded-md" />
    </div>
  </dialog>
</BaseLayout>

<script>
  function setupLightbox() {
    const dialog = document.getElementById("lightbox") as HTMLDialogElement;
    const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
    if (!dialog || !lightboxImg) return;

    const triggers = document.querySelectorAll(".lightbox-trigger");
    triggers.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        const src = btn.getAttribute("data-img-src");
        if (src) {
          lightboxImg.src = src;
          dialog.showModal();
        }
      });
    });

    dialog.addEventListener("click", () => {
      dialog.close();
    });
  }

  setupLightbox();
  document.addEventListener("astro:page-load", setupLightbox);
</script>

<style>
  dialog::backdrop {
    background: transparent;
  }
</style>
