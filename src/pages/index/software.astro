---
/**
 * 학습지원 소프트웨어 — 원본(docs/original/CONTENT.md §6).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import LinkButton from '../../components/LinkButton.astro';
import Carousel from '../../components/Carousel.astro';
import PageNavigation from '../../components/PageNavigation.astro';

const all = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/pages/software/*.{png,jpg,jpeg,webp}',
  { eager: true }
);

const imgs = Object.entries(all)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, m]) => m.default);

const slideImages = imgs.map((img, i) => ({
  src: img.src,
  alt: `학습지원 소프트웨어 슬라이드 ${i + 1}`,
  caption: '원본 네이버 블로그 참고'
}));
---

<BaseLayout
  title="학습지원 소프트웨어"
  description="학습지원 소프트웨어 선정기준 관련 자료 안내"
>
  <section class="mx-auto max-w-3xl px-5 py-12 sm:py-14">
    <h1 class="title-underline text-center text-[24px] font-bold leading-tight text-ink sm:text-[30px]">
      학습지원 소프트웨어
    </h1>

    <div class="mt-10">
      {
        slideImages.length > 0 ? (
          <Carousel images={slideImages} />
        ) : (
          <div class="rounded-md border-2 border-dashed border-line bg-white/50 px-4 py-8 text-center">
            <p class="text-[14px] font-semibold text-muted">캐러셀 이미지 자리 — 학습지원 소프트웨어</p>
            <p class="mt-1.5 font-mono text-[12px] text-muted">
              src/assets/pages/software/ 폴더에 이미지를 넣으면 자동 캐러셀이 표시됩니다.
            </p>
            <p class="mt-1 text-[12px] text-muted">원본 네이버 블로그 이미지를 참고하여 추가해주세요.</p>
          </div>
        )
      }
    </div>

    <div class="mt-10 flex flex-wrap items-center justify-between gap-3 rounded-[var(--radius-card)] border border-line bg-white p-5 shadow-[var(--shadow-card)]">
      <p class="text-[16px] font-semibold text-ink">학습지원 소프트웨어 선정기준 관련 자료 탑재 →</p>
      <LinkButton href="https://edzip.kr/utilization/learning-sw" variant="primary" external>
        자세히 보기(에듀집)
      </LinkButton>
    </div>

    <PageNavigation 
      prev={{ title: 'AI·디지털 교육자료 활용 도움자료', href: '/index/AIDT' }}
    />
  </section>
</BaseLayout>
