---
/**
 * 사전 준비사항 안내 — 원본(docs/original/CONTENT.md §3).
 * 탭 스타일 및 비디오 플레이스홀더 적용.
 */
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LinkButton from "../../components/LinkButton.astro";
import PageNavigation from "../../components/PageNavigation.astro";

// 이미지 직접 임포트
import imgCard1 from "../../assets/pages/manual/001.png";
import imgCard2 from "../../assets/pages/manual/002.png";
import imgCard3 from "../../assets/pages/manual/003.png";
import imgCard4 from "../../assets/pages/manual/004.png";
---

<BaseLayout
  title="사전 준비사항 안내"
  description="AI·디지털 교육자료 사용을 위한 사전 준비사항 — NEIS 연동, 교육디지털원패스 가입, 교육부 도움자료, 안내장"
>
  <section class="mx-auto max-w-4xl px-5 py-12 sm:py-14">
    <h1
      class="title-underline text-center text-[24px] font-bold leading-tight text-ink sm:text-[30px]"
    >
      AI·디지털 교육자료 사용을 위한 사전 준비사항 안내
    </h1>

    <!-- 1단계 ~ 4단계 대표 이미지 가로 배열 (맨 위 배치) -->
    <div
      class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-4"
      id="top-images-grid"
    >
      <button
        class="top-img-btn active cursor-pointer border-2 border-primary-500 rounded-lg overflow-hidden shadow-sm transition-all hover:scale-[1.02] outline-none"
        data-target="step1"
        aria-label="1단계 보기"
      >
        <Image
          src={imgCard1}
          alt="1단계 [교사] NEIS 교육과정 담당자"
          class="w-full h-auto object-cover object-top aspect-[4/3]"
        />
        <div
          class="bg-primary-500 text-white text-[12px] font-bold py-1 text-center"
        >
          1단계 [교사] NEIS 교육과정 담당자
        </div>
      </button>
      <button
        class="top-img-btn cursor-pointer border-2 border-transparent rounded-lg overflow-hidden shadow-sm transition-all hover:scale-[1.02] outline-none"
        data-target="step2"
        aria-label="2단계 보기"
      >
        <Image
          src={imgCard2}
          alt="2단계 [교사] 담임 및 지도교사"
          class="w-full h-auto object-cover object-top aspect-[4/3]"
        />
        <div
          class="bg-gray-100 text-ink text-[12px] font-bold py-1 text-center group-hover:bg-primary-500"
        >
          2단계 [교사] 담임 및 지도교사
        </div>
      </button>
      <button
        class="top-img-btn cursor-pointer border-2 border-transparent rounded-lg overflow-hidden shadow-sm transition-all hover:scale-[1.02] outline-none"
        data-target="step3"
        aria-label="3단계 보기"
      >
        <Image
          src={imgCard3}
          alt="3단계 [학생] 처음 가입 학생"
          class="w-full h-auto object-cover object-top aspect-[4/3]"
        />
        <div
          class="bg-gray-100 text-ink text-[12px] font-bold py-1 text-center"
        >
          3단계 [학생] 처음 가입 학생
        </div>
      </button>
      <button
        class="top-img-btn cursor-pointer border-2 border-transparent rounded-lg overflow-hidden shadow-sm transition-all hover:scale-[1.02] outline-none"
        data-target="step4"
        aria-label="4단계 보기"
      >
        <Image
          src={imgCard4}
          alt="4단계 [학생] 계정 있는 학생"
          class="w-full h-auto object-cover object-top aspect-[4/3]"
        />
        <div
          class="bg-gray-100 text-ink text-[12px] font-bold py-1 text-center"
        >
          4단계 [학생] 계정 있는 학생
        </div>
      </button>
    </div>

    <!-- 탭 콘텐츠 영역 -->
    <div class="mt-8 min-h-[350px]">
      <!-- 1단계 [교사] NEIS 교육과정 담당자 -->
      <div id="step1" class="manual-tab-content block space-y-6">
        <div class="flex flex-col md:flex-row gap-6 items-start">
          <div class="w-full md:w-1/2">
            <button class="w-full block outline-none focus:ring-4 focus:ring-primary-500 rounded-lg transition-transform hover:opacity-95 cursor-zoom-in lightbox-trigger" data-img-src={imgCard1.src} aria-label="1단계 [교사] NEIS 교육과정 담당자 이미지 크게 보기">
              <Image
                src={imgCard1}
                alt="1단계 [교사] NEIS 교육과정 담당자"
                class="w-full h-auto rounded-lg border border-line shadow-sm"
              />
            </button>
          </div>
          <div class="w-full md:w-1/2">
            <h2 class="text-[19px] font-bold text-ink">
              1단계 [교사] NEIS 교육과정 담당자
            </h2>
            <p class="mt-2 text-[15px] font-semibold text-ink">
              NEIS 담당 선생님께서 사전 작업을 해주셔야 해요
            </p>
            <ul class="mt-3 space-y-1.5 text-[15px] leading-relaxed text-muted">
              <li>
                ✅ 교육디지털원패스 및 AI·디지털 교육자료 포털은 나이스의 학적
                정보와 연동(<b><button type="button" id="open-presentation-btn" class="text-primary-600 hover:underline cursor-pointer">자세히 보기</button></b>)
              </li>
              <li>✅ 학급시간표에서 AI·디지털 교육자료 과목 배정</li>
              <li>
                ✅ 나이스 변동 사항이 있을 경우 AI·디지털 교육자료 시스템에
                반영은 <b>익일</b>
              </li>
              <li>✅ 초등 : <b>[출결일괄편성]</b></li>
              <li>✅ 중등 : <b>[수강학생편성]</b></li>
            </ul>
          </div>
        </div>
        <!-- 비디오 세트 (Vimeo 임베드) -->
        <div
          class="mt-6 rounded-[var(--radius-card)] border border-line bg-gray-50 p-5"
        >
          <p
            class="text-[15px] font-bold text-ink mb-3 flex items-center gap-1.5"
          >
            <span>🎥 1단계 [교사] NEIS 교육과정 담당자</span>
          </p>
          <div
            class="relative w-full aspect-video rounded-lg overflow-hidden shadow-sm border border-line bg-black"
          >
            <iframe
              src="https://player.vimeo.com/video/1159227053"
              class="absolute top-0 left-0 w-full h-full"
              frameborder="0"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
            >
            </iframe>
          </div>
        </div>
      </div>

      <!-- 2단계 [교사] 담임 및 지도교사 -->
      <div id="step2" class="manual-tab-content hidden space-y-6">
        <div class="flex flex-col md:flex-row gap-6 items-start">
          <div class="w-full md:w-1/2">
            <button class="w-full block outline-none focus:ring-4 focus:ring-primary-500 rounded-lg transition-transform hover:opacity-95 cursor-zoom-in lightbox-trigger" data-img-src={imgCard2.src} aria-label="2단계 [교사] 담임 및 지도교사 이미지 크게 보기">
              <Image
                src={imgCard2}
                alt="2단계 [교사] 담임 및 지도교사"
                class="w-full h-auto rounded-lg border border-line shadow-sm"
              />
            </button>
          </div>
          <div class="w-full md:w-1/2">
            <h2 class="text-[19px] font-bold text-ink">
              2단계 [교사] 담임 및 지도교사
            </h2>
            <p class="mt-2 text-[15px] font-semibold text-ink">
              AI·디지털 교육자료 포털에 교육디지털원패스로 로그인해요
            </p>
            <div class="mt-3 flex flex-wrap gap-2.5">
              <LinkButton
                href="https://edupass.neisplus.kr/"
                variant="primary"
                external>교육디지털원패스(바로가기)</LinkButton
              >
              <LinkButton
                href="/index/eduonepass"
                variant="ghost">더 알아보기</LinkButton
              >
            </div>
            <ul class="mt-3 space-y-1.5 text-[15px] leading-relaxed text-muted">
              <li>✅ 교육디지털원패스 회원에 가입하기</li>
              <li>✅ AI·디지털 교육자료 포털에 로그인하기</li>
              <li>✅ 약관 동의 후 사용하기</li>
            </ul>
          </div>
        </div>
        <!-- 비디오 세트 (Vimeo 임베드) -->
        <div
          class="mt-6 rounded-[var(--radius-card)] border border-line bg-gray-50 p-5"
        >
          <p
            class="text-[15px] font-bold text-ink mb-3 flex items-center gap-1.5"
          >
            <span>🎥 2단계 [교사] 담임 및 지도교사</span>
          </p>
          <div
            class="relative w-full aspect-video rounded-lg overflow-hidden shadow-sm border border-line bg-black"
          >
            <iframe
              src="https://player.vimeo.com/video/1159227722"
              class="absolute top-0 left-0 w-full h-full"
              frameborder="0"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
            >
            </iframe>
          </div>
        </div>
      </div>

      <!-- 3단계 [학생] 처음 가입 학생 -->
      <div id="step3" class="manual-tab-content hidden space-y-6">
        <div class="flex flex-col md:flex-row gap-6 items-start">
          <div class="w-full md:w-1/2">
            <button class="w-full block outline-none focus:ring-4 focus:ring-primary-500 rounded-lg transition-transform hover:opacity-95 cursor-zoom-in lightbox-trigger" data-img-src={imgCard3.src} aria-label="3단계 [학생] 처음 가입 학생 이미지 크게 보기">
              <Image
                src={imgCard3}
                alt="3단계 [학생] 처음 가입 학생"
                class="w-full h-auto rounded-lg border border-line shadow-sm"
              />
            </button>
          </div>
          <div class="w-full md:w-1/2">
            <h2 class="text-[19px] font-bold text-ink">
              3단계 [학생] 처음 가입 학생
            </h2>
            <p class="mt-2 text-[15px] font-semibold text-ink">
              AI·디지털 교육자료를 활용하기 위해 교육디지털원패스가 필요해요
            </p>
            <div class="mt-3 flex flex-wrap gap-2.5">
              <LinkButton
                href="https://edupass.neisplus.kr/"
                variant="primary"
                external>교육디지털원패스(바로가기)</LinkButton
              >
              <LinkButton
                href="/index/eduonepass"
                variant="ghost">더 알아보기</LinkButton
              >
            </div>
            <ul class="mt-3 space-y-1.5 text-[15px] leading-relaxed text-muted">
              <li>✅ 교육디지털원패스 회원에 가입하기</li>
              <li>✅ AI·디지털 교육자료 포털에 로그인하기</li>
              <li>✅ 약관 동의 후 사용하기</li>
            </ul>
          </div>
        </div>
        <!-- 비디오 세트 (Vimeo 임베드) -->
        <div
          class="mt-6 rounded-[var(--radius-card)] border border-line bg-gray-50 p-5"
        >
          <p
            class="text-[15px] font-bold text-ink mb-3 flex items-center gap-1.5"
          >
            <span>🎥 3단계 [학생] 처음 가입 학생</span>
          </p>
          <div
            class="relative w-full aspect-video rounded-lg overflow-hidden shadow-sm border border-line bg-black"
          >
            <iframe
              src="https://player.vimeo.com/video/1159228239"
              class="absolute top-0 left-0 w-full h-full"
              frameborder="0"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
            >
            </iframe>
          </div>
        </div>
      </div>

      <!-- 4단계 [학생] 계정 있는 학생 -->
      <div id="step4" class="manual-tab-content hidden space-y-6">
        <div class="flex flex-col md:flex-row gap-6 items-start">
          <div class="w-full md:w-1/2">
            <button class="w-full block outline-none focus:ring-4 focus:ring-primary-500 rounded-lg transition-transform hover:opacity-95 cursor-zoom-in lightbox-trigger" data-img-src={imgCard4.src} aria-label="4단계 [학생] 계정 있는 학생 이미지 크게 보기">
              <Image
                src={imgCard4}
                alt="4단계 [학생] 계정 있는 학생"
                class="w-full h-auto rounded-lg border border-line shadow-sm"
              />
            </button>
          </div>
          <div class="w-full md:w-1/2">
            <h2 class="text-[19px] font-bold text-ink">
              4단계 [학생] 계정 있는 학생
            </h2>
            <p class="mt-2 text-[15px] font-semibold text-ink">
              나의 계정을 확인하고 AI·디지털 교육자료에 로그인해요
            </p>
            <div class="mt-3 flex flex-wrap gap-2.5">
              <LinkButton
                href="https://www.aidtbook.kr/index.do"
                variant="primary"
                external>AI·디지털 교육자료 포털(바로가기)</LinkButton
              >
              <LinkButton
                href="/index/AIDT"
                variant="ghost">도움자료</LinkButton
              >
            </div>
            <ul class="mt-3 space-y-1.5 text-[15px] leading-relaxed text-muted">
              <li>
                ✅ AI·디지털 교육자료 포털에 접속하고 '교육디지털원패스'로
                로그인하기
              </li>
              <li>✅ AI·디지털 교육자료 약관 동의 후 사용하기</li>
            </ul>
          </div>
        </div>
        <!-- 비디오 세트 (Vimeo 임베드) -->
        <div
          class="mt-6 rounded-[var(--radius-card)] border border-line bg-gray-50 p-5"
        >
          <p
            class="text-[15px] font-bold text-ink mb-3 flex items-center gap-1.5"
          >
            <span>🎥 4단계 [학생] 계정 있는 학생</span>
          </p>
          <div
            class="relative w-full aspect-video rounded-lg overflow-hidden shadow-sm border border-line bg-black"
          >
            <iframe
              src="https://player.vimeo.com/video/1159228440"
              class="absolute top-0 left-0 w-full h-full"
              frameborder="0"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
            >
            </iframe>
          </div>
        </div>
      </div>
    </div>

    <PageNavigation
      next={{ title: "AI·디지털 교육자료 활용 도움자료", href: "/index/AIDT" }}
    />
  </section>

  <!-- Lightbox Dialog -->
  <dialog id="lightbox" class="fixed inset-0 z-50 w-full h-full max-w-none bg-black/80 backdrop-blur-sm p-4 m-0 flex-col items-center justify-center opacity-0 transition-opacity duration-300 open:flex open:opacity-100 cursor-zoom-out" aria-modal="true">
    <div class="relative w-full max-w-[95vw] max-h-[95vh] overflow-auto hide-scrollbar text-center flex items-center justify-center">
      <img id="lightbox-img" src="" alt="크게 보기" class="max-w-full max-h-[90vh] object-contain cursor-default bg-white rounded-md" />
    </div>
  </dialog>

  <!-- Presentation Dialog -->
  <dialog id="presentation-dialog" class="fixed inset-0 z-50 w-full h-full max-w-none bg-black/80 backdrop-blur-sm p-4 m-0 flex-col items-center justify-center opacity-0 transition-opacity duration-300 open:flex open:opacity-100" aria-modal="true">
    <div class="relative w-full max-w-[95vw] h-[85vh] bg-white rounded-md overflow-hidden flex flex-col shadow-lg">
      <div class="flex justify-between items-center px-4 py-2.5 border-b border-line bg-gray-50">
        <span class="font-bold text-[15px] text-ink">나이스 학적 연동 자세히 보기</span>
        <button id="close-presentation" class="text-muted hover:text-ink font-bold text-[22px] cursor-pointer">&times;</button>
      </div>
      <iframe 
        src="https://docs.google.com/presentation/d/11IYnnYoewSyIgmL_U06spAPUJf96UM_mGmLcwE9TIEs/present" 
        class="w-full flex-grow border-0" 
        allowfullscreen>
      </iframe>
    </div>
  </dialog>
</BaseLayout>

<script>
  function setupManualTabs() {
    const topBtns = document.querySelectorAll(".top-img-btn");
    const tabBtns = document.querySelectorAll(".manual-tab-btn");
    const contents = document.querySelectorAll(".manual-tab-content");

    function activateTab(targetId: string) {
      // 1. 탑 이미지 보더 갱신
      topBtns.forEach((btn) => {
        const target = btn.getAttribute("data-target");
        const textDiv = btn.querySelector("div");
        if (target === targetId) {
          btn.classList.add("border-primary-500");
          btn.classList.remove("border-transparent");
          if (textDiv) {
            textDiv.className =
              "bg-primary-500 text-white text-[12px] font-bold py-1 text-center";
          }
        } else {
          btn.classList.remove("border-primary-500");
          btn.classList.add("border-transparent");
          if (textDiv) {
            textDiv.className =
              "bg-gray-100 text-ink text-[12px] font-bold py-1 text-center";
          }
        }
      });

      // 2. 탭 버튼 상태 갱신
      tabBtns.forEach((btn) => {
        const target = btn.getAttribute("data-target");
        if (target === targetId) {
          btn.classList.add("active", "border-primary-500", "text-primary-600");
          btn.classList.remove("border-transparent", "text-muted");
          btn.setAttribute("aria-selected", "true");
        } else {
          btn.classList.remove(
            "active",
            "border-primary-500",
            "text-primary-600",
          );
          btn.classList.add("border-transparent", "text-muted");
          btn.setAttribute("aria-selected", "false");
        }
      });

      // 3. 탭 콘텐츠 표시 전환
      contents.forEach((content) => {
        if (content.id === targetId) {
          content.classList.remove("hidden");
          content.classList.add("block");
        } else {
          content.classList.remove("block");
          content.classList.add("hidden");
        }
      });
    }

    // 탑 이미지 클릭 리스너
    topBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = btn.getAttribute("data-target");
        if (target) activateTab(target);
      });
    });

    // 탭 버튼 클릭 리스너
    tabBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = btn.getAttribute("data-target");
        if (target) activateTab(target);
      });
    });
  }

  function setupLightbox() {
    const dialog = document.getElementById("lightbox") as HTMLDialogElement;
    const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
    if (!dialog || !lightboxImg) return;

    const triggers = document.querySelectorAll(".lightbox-trigger");
    triggers.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        const src = btn.getAttribute("data-img-src");
        if (src) {
          lightboxImg.src = src;
          dialog.showModal();
        }
      });
    });

    dialog.addEventListener("click", () => {
      dialog.close();
    });
  }

  function setupPresentationModal() {
    const dialog = document.getElementById("presentation-dialog") as HTMLDialogElement;
    const openBtn = document.getElementById("open-presentation-btn");
    const closeBtn = document.getElementById("close-presentation");
    if (!dialog || !openBtn || !closeBtn) return;

    openBtn.addEventListener("click", (e) => {
      e.preventDefault();
      dialog.showModal();
    });

    closeBtn.addEventListener("click", () => {
      dialog.close();
    });

    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) {
        dialog.close();
      }
    });
  }

  setupManualTabs();
  setupLightbox();
  setupPresentationModal();
  document.addEventListener("astro:page-load", () => {
    setupManualTabs();
    setupLightbox();
    setupPresentationModal();
  });
</script>

<style>
  dialog::backdrop {
    background: transparent;
  }
</style>
