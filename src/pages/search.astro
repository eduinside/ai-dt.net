---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="검색" description="사이트 내 문서 및 자료 통합 검색">
  <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6 lg:py-16">
    <div class="mb-8">
      <h1 class="text-2xl font-bold tracking-tight text-ink sm:text-3xl">사이트 내 검색</h1>
      <p class="mt-2 text-sm text-muted">
        사전 준비사항, AI·디지털 교육자료 도움자료, 교육디지털원패스, 학습지원 소프트웨어, 자주 묻는 질문(FAQ) 및 발행사 답변 내용을 실시간으로 검색합니다.
      </p>
    </div>

    <!-- Pagefind가 검색 인터페이스를 렌더링할 타겟 컨테이너 -->
    <div id="search" class="min-h-[300px]"></div>
  </div>
</BaseLayout>

<!-- Pagefind UI 번들 리소스 로드 -->
<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script is:inline src="/pagefind/pagefind-ui.js"></script>

<script is:inline>
  window.addEventListener('DOMContentLoaded', () => {
    if (typeof PagefindUI !== 'undefined') {
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        translations: {
          placeholder: "검색어를 입력해 주세요 (예: NEIS, 교육디지털원패스, 금성)",
          clear_search: "지우기",
          load_more: "결과 더 보기",
          search_label: "검색",
          filters_label: "필터",
          zero_results: "[search]에 대한 검색 결과가 없습니다.",
          many_results: "[search]에 대한 검색 결과 [count]건",
          one_result: "[search]에 대한 검색 결과 1건",
          alt_search: "[search]에 대한 다른 검색 결과가 있습니다. 검색어를 다시 확인해 주세요."
        }
      });
    } else {
      document.getElementById('search').innerHTML = 
        `<div class="rounded-lg border border-yellow-200 bg-yellow-50 p-5 text-sm text-yellow-800 leading-relaxed shadow-sm">
          <p class="font-semibold mb-1">💡 안내 사항</p>
          로컬 개발 서버(dev)에서는 정적 검색 인덱스가 활성화되지 않습니다.<br />
          실제 작동은 <strong>npm run build</strong> 실행 후 <strong>npm run preview</strong> 또는 배포된 서버에서 확인하실 수 있습니다.
        </div>`;
    }
  });
</script>

<style is:global>
  /* Pagefind UI의 스타일을 프로젝트 디자인 테마(딥 틸 #0f7d84, 웜 코랄 #e2623b)와 어울리도록 커스텀 */
  :root {
    --pagefind-ui-primary: #0f7d84;
    --pagefind-ui-text: #1d2c33;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #e2e8f0;
    --pagefind-ui-tag: #f1f5f9;
  }
  
  .pagefind-ui .pagefind-ui__search-input {
    font-size: 1rem;
    font-weight: 500;
    border-radius: 0.5rem;
    border: 1px solid var(--pagefind-ui-border);
    transition: all 0.2s ease;
  }

  .pagefind-ui .pagefind-ui__search-input:focus {
    outline: none;
    border-color: var(--pagefind-ui-primary);
    box-shadow: 0 0 0 3px rgba(15, 125, 132, 0.15);
  }

  .pagefind-ui .pagefind-ui__search-clear {
    border-radius: 0.375rem;
    background-color: var(--pagefind-ui-tag);
    color: var(--pagefind-ui-text);
  }

  .pagefind-ui .pagefind-ui__result {
    border-top: 1px solid var(--pagefind-ui-border);
    padding: 1.5rem 0;
  }

  .pagefind-ui .pagefind-ui__result-title a {
    color: var(--pagefind-ui-primary);
    font-weight: 700;
    text-decoration: none;
  }

  .pagefind-ui .pagefind-ui__result-title a:hover {
    text-decoration: underline;
  }

  .pagefind-ui .pagefind-ui__result-excerpt {
    color: #4a5d66;
    font-size: 0.925rem;
    margin-top: 0.5rem;
    line-height: 1.6;
  }

  .pagefind-ui .pagefind-ui__result-excerpt mark {
    background-color: rgba(226, 98, 59, 0.15); /* 웜 코랄 투명 배경 */
    color: #e2623b; /* 웜 코랄 강조 색상 */
    font-weight: 600;
    padding: 0 0.125rem;
    border-radius: 0.125rem;
  }
</style>
