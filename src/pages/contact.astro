---
/**
 * 문의 및 장애 지원 — 원본(docs/original/CONTENT.md §14) 텍스트 그대로.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import LinkButton from '../components/LinkButton.astro';
import PageImages from '../components/PageImages.astro';
---

<BaseLayout
  title="문의 및 장애 지원"
  description="AI·디지털 교육자료 관련 문의 및 장애 지원 안내 — 중앙상담센터, 테크센터, 교육디지털원패스"
>
  <section class="mx-auto max-w-3xl px-5 py-12 sm:py-14">
    <h1 class="title-underline text-center text-[24px] font-bold leading-tight text-ink sm:text-[30px]">
      AI·디지털 교육자료 관련 문의 및 장애 지원
    </h1>

    <div class="mt-10 space-y-5">
      <!-- 교육부 중앙상담센터 -->
      <article class="rounded-[var(--radius-card)] border border-line bg-white p-6 shadow-[var(--shadow-card)]">
        <h2 class="text-[18px] font-bold text-ink">
          [교육부] AI·디지털 교육자료 중앙상담센터
          <span class="text-primary-600">(1600-2525)</span>
        </h2>
        <dl class="mt-4 space-y-3 text-[15px] leading-relaxed">
          <div>
            <dt class="font-semibold text-ink">지원 내용</dt>
            <dd class="text-muted">AI 디지털교과서 플랫폼 문의 및 장애 지원</dd>
          </div>
          <div>
            <dt class="font-semibold text-ink">접수 / 처리</dt>
            <dd class="text-muted">
              ARS(1600-2525) ·
              <a href="https://www.aidtbook.kr" target="_blank" rel="noopener noreferrer" class="text-primary-600 underline underline-offset-2">온라인(www.aidtbook.kr)</a>
            </dd>
          </div>
        </dl>
      </article>

      <!-- 우리교육청 테크센터 -->
      <article class="rounded-[var(--radius-card)] border border-line bg-white p-6 shadow-[var(--shadow-card)]">
        <h2 class="text-[18px] font-bold text-ink">[우리교육청] 테크센터 운영</h2>
        <dl class="mt-4 space-y-3 text-[15px] leading-relaxed">
          <div>
            <dt class="font-semibold text-ink">지원 내용</dt>
            <dd class="text-muted">
              학교 디지털인프라 관련 사항 상담 신청<br />
              <span class="text-[13px]">* 학교망(스쿨넷, 무선망), 무선통신장비, 무선 접속, 스마트기기 관련</span>
            </dd>
          </div>
          <div>
            <dt class="font-semibold text-ink">접수 / 처리</dt>
            <dd class="text-muted">
              통합콜센터 (☎ 235-9999) 근무시간 : 09:00 ~ 18:00(공휴일, 점심시간 제외)<br />
              <a href="https://tech.dge.go.kr" target="_blank" rel="noopener noreferrer" class="text-primary-600 underline underline-offset-2">테크센터포털(tech.dge.go.kr)</a>
              : 운영 관련 시스템(무선인증, MDM) 연결 지원
            </dd>
          </div>
        </dl>
      </article>

      <!-- 교육디지털원패스 -->
      <article class="rounded-[var(--radius-card)] border border-line bg-white p-6 shadow-[var(--shadow-card)]">
        <h2 class="text-[18px] font-bold text-ink">
          교육디지털원패스
          <span class="text-primary-600">콜센터 (☎ 1600-7440)</span>
        </h2>
      </article>

      <!-- 사용자 문의 이용 안내 -->
      <article class="rounded-[var(--radius-card)] border border-line bg-white p-6 shadow-[var(--shadow-card)]">
        <h2 class="text-[18px] font-bold text-ink">사용자 문의 이용 안내</h2>
        <div class="mt-5 text-center" id="guide-container">
          <button class="w-full max-w-[900px] outline-none focus:ring-4 focus:ring-primary-500 rounded-md transition-transform hover:opacity-95 cursor-zoom-in" aria-label="가이드 이미지 크게 보기">
            <PageImages slug="contact/guide" alt="가입 및 이용방법 가이드 이미지" note="사용자 가이드 안내 이미지 자리" />
          </button>
        </div>
      </article>
    </div>
  </section>

  <!-- Lightbox Dialog -->
  <dialog id="lightbox" class="fixed inset-0 z-50 w-full h-full max-w-none bg-black/80 backdrop-blur-sm p-4 m-0 flex-col items-center justify-center opacity-0 transition-opacity duration-300 open:flex open:opacity-100 cursor-zoom-out" aria-label="닫기">
    <div class="relative w-full max-w-5xl max-h-full overflow-auto hide-scrollbar text-center flex items-center justify-center">
      <img id="lightbox-img" src="" alt="크게 보기" class="max-w-full h-auto object-contain cursor-default bg-white rounded-md" />
    </div>
  </dialog>
</BaseLayout>

<script>
  function setupLightbox() {
    const container = document.getElementById('guide-container');
    const dialog = document.getElementById('lightbox') as HTMLDialogElement;
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    
    if (!container || !dialog || !lightboxImg) return;

    // container 안의 이미지를 클릭하면 해당 src를 dialog에 띄움
    container.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.tagName === 'IMG') {
        const img = target as HTMLImageElement;
        lightboxImg.src = img.src;
        dialog.showModal();
      } else {
        // img를 직접 클릭하지 않았으나 버튼 영역인 경우, 첫 번째 이미지를 띄움
        const firstImg = container.querySelector('img');
        if (firstImg) {
          lightboxImg.src = firstImg.src;
          dialog.showModal();
        }
      }
    });

    dialog.addEventListener('click', () => {
      dialog.close();
    });
  }

  setupLightbox();
  document.addEventListener('astro:page-load', setupLightbox);
</script>

<style>
  dialog::backdrop {
    background: transparent;
  }
</style>
