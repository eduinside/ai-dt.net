---
/**
 * 문의 및 장애 지원 — 원본(docs/original/CONTENT.md §14) 텍스트 그대로.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import LinkButton from '../components/LinkButton.astro';
import PageImages from '../components/PageImages.astro';
---

<BaseLayout
  title="문의 및 장애 지원"
  description="AI·디지털 교육자료 관련 문의 및 장애 지원 안내 — 중앙상담센터, 테크센터, 교육디지털원패스"
>
  <section class="mx-auto max-w-3xl px-5 py-12 sm:py-14">
    <h1 class="title-underline text-center text-[24px] font-bold leading-tight text-ink sm:text-[30px]">
      AI·디지털 교육자료 관련 문의 및 장애 지원
    </h1>

    <div class="mt-10 space-y-5">
      <!-- 교육부 중앙상담센터 -->
      <article class="rounded-[var(--radius-card)] border border-line bg-white p-6 shadow-[var(--shadow-card)]">
        <h2 class="text-[18px] font-bold text-ink">
          [교육부] AI·디지털 교육자료 중앙상담센터
          <span class="text-primary-600">(1600-2525)</span>
        </h2>
        <dl class="mt-4 space-y-3 text-[15px] leading-relaxed">
          <div>
            <dt class="font-semibold text-ink">지원 내용</dt>
            <dd class="text-muted">AI 디지털교과서 플랫폼 문의 및 장애 지원</dd>
          </div>
          <div>
            <dt class="font-semibold text-ink">접수 / 처리</dt>
            <dd class="text-muted">
              ARS(1600-2525) ·
              <a href="https://www.aidtbook.kr" target="_blank" rel="noopener noreferrer" class="text-primary-600 underline underline-offset-2">온라인(www.aidtbook.kr)</a>
            </dd>
          </div>
        </dl>
      </article>

      <!-- 우리교육청 테크센터 -->
      <article class="rounded-[var(--radius-card)] border border-line bg-white p-6 shadow-[var(--shadow-card)]">
        <h2 class="text-[18px] font-bold text-ink">[우리교육청] 테크센터 운영</h2>
        <dl class="mt-4 space-y-3 text-[15px] leading-relaxed">
          <div>
            <dt class="font-semibold text-ink">지원 내용</dt>
            <dd class="text-muted">
              학교 디지털인프라 관련 사항 상담 신청<br />
              <span class="text-[13px]">* 학교망(스쿨넷, 무선망), 무선통신장비, 무선 접속, 스마트기기 관련</span>
            </dd>
          </div>
          <div>
            <dt class="font-semibold text-ink">접수 / 처리</dt>
            <dd class="text-muted">
              통합콜센터 (☎ 235-9999) 근무시간 : 09:00 ~ 18:00(공휴일, 점심시간 제외)<br />
              <a href="https://tech.dge.go.kr" target="_blank" rel="noopener noreferrer" class="text-primary-600 underline underline-offset-2">테크센터포털(tech.dge.go.kr)</a>
              : 운영 관련 시스템(무선인증, MDM) 연결 지원
            </dd>
          </div>
        </dl>
      </article>

      <!-- 교육디지털원패스 -->
      <article class="rounded-[var(--radius-card)] border border-line bg-white p-6 shadow-[var(--shadow-card)]">
        <h2 class="text-[18px] font-bold text-ink">
          교육디지털원패스
          <span class="text-primary-600">콜센터 (☎ 1600-7440)</span>
        </h2>
      </article>

      <!-- 사용자 문의 이용 안내 -->
      <article class="rounded-[var(--radius-card)] border border-line bg-white p-6 shadow-[var(--shadow-card)]">
        <h2 class="text-[18px] font-bold text-ink">사용자 문의 이용 안내</h2>
        <p class="mt-2 text-[15px] leading-relaxed text-muted">
          가입 및 이용방법 가이드를 먼저 확인해 보세요. 해결되지 않는 문제는 고객센터나 카카오톡 채널을 통해 문의하실 수 있습니다.
        </p>
        <div class="mt-5">
          <PageImages slug="contact/guide" alt="가입 및 이용방법 가이드 이미지" note="사용자 가이드 안내 이미지 자리" />
        </div>
        <div class="mt-5 flex flex-wrap gap-3">
          <LinkButton href="https://www.aidtbook.kr" variant="ghost" external>
            고객센터 문의하기
          </LinkButton>
          <LinkButton href="https://pf.kakao.com" variant="ghost" external>
            카카오톡 채널 바로가기
          </LinkButton>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
