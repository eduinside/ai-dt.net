---
/**
 * 홈 — 원본(docs/original/CONTENT.md §2) 충실 재현.
 * 모든 문구는 원본 그대로. 부가 텍스트·요소 삽입 없음.
 */
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import LinkButton from '../components/LinkButton.astro';
import ReplyBoard from '../components/ReplyBoard.astro';
import { faqRows } from '../data/faq';
import logo from '../assets/logo-512.webp';
---

<BaseLayout>
  <!-- 히어로 — 밝은 시안 배경, 중앙 정렬 -->
  <section
    class="border-b border-line"
    style="background:
      radial-gradient(900px 420px at 20% 20%, var(--color-hero-from), transparent 70%),
      radial-gradient(800px 400px at 85% 10%, var(--color-hero-mid), transparent 65%),
      linear-gradient(150deg, var(--color-hero-from), var(--color-hero-to))"
  >
    <div class="mx-auto max-w-4xl px-5 pb-16 pt-12 text-center sm:pb-20 sm:pt-16 animate-fade-in-up">
      <Image src={logo} alt="" width={192} height={192} class="mx-auto mb-5 h-20 w-20 sm:h-24 sm:w-24" loading="eager" />
      <p class="text-[17px] text-ink">대구광역시교육청</p>
      <h1 class="title-underline mt-2 text-[32px] font-bold leading-tight tracking-tight text-ink sm:text-[44px]">
        AI·디지털 교육자료 수업 지원센터
      </h1>
      <p class="mx-auto mt-7 max-w-xl text-[16px] leading-relaxed text-ink sm:text-[17px]">
        대구광역시교육청이 AI·디지털 교육자료를 손쉽게 활용하여<br
          class="hidden sm:block"
        />
        창의적이고 효과적인 수업을 할 수 있도록 지원합니다.
      </p>
    </div>
  </section>

  <!-- 연회색 밴드 — 대표 연락처 2건 -->
  <section class="border-b border-line bg-[var(--color-band)] animate-fade-in-up delay-75">
    <div class="mx-auto grid max-w-5xl gap-6 px-5 py-8 text-center sm:grid-cols-2">
      <div>
        <p class="font-bold text-ink">[AI·디지털 교육자료 포털]</p>
        <p class="mt-1 text-[18px] font-bold text-ink">중앙상담센터 1600-2525</p>
      </div>
      <div>
        <p class="font-bold text-ink">[회원가입 관련]</p>
        <p class="mt-1 text-[18px] font-bold text-ink">교육디지털원패스 1600-7440</p>
      </div>
    </div>
  </section>

  <!-- FAQ · 도움자료 섹션 -->
  <section class="mx-auto max-w-4xl px-5 pt-12 animate-fade-in-up delay-150">
    <div class="flex items-center justify-between border-b border-line pb-3">
      <h2 class="text-[18px] font-bold text-ink">선도학교 운영 관련 FAQ</h2>
      <a href="/index/faq" class="text-[14px] font-semibold text-primary-600 hover:text-primary-700 transition-colors flex items-center gap-1">
        더 보기
        <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="shrink-0">
          <path d="M5 12l5-5-5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>

    <!-- 원본 GAS QnA 게시판을 정적 FAQ 게시판으로 이관 (src/data/faq.ts 공유) -->
    <div class="mt-4">
      <ReplyBoard rows={faqRows} showPublisher={false} linkToFaq={true} />
    </div>

    <a
      href="/index/AIDT"
      class="mt-6 block bg-primary-600 py-3.5 text-center text-[15px] font-semibold text-white transition-all duration-300 rounded-lg shadow-sm hover:shadow-md hover:bg-primary-700"
    >
      활용 도움자료 더 보기
    </a>
  </section>

  <!-- 다크 밴드 — 절차 안내 -->
  <section class="mt-14 bg-primary-600 animate-fade-in-up delay-200">
    <div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 px-5 py-6 sm:flex-row">
      <p class="text-[15px] font-semibold text-white sm:text-[16px]">
        AI·디지털 교육자료 활용을 위해 필요한 절차를 단계별로 정리해 보았습니다.
      </p>
      <LinkButton href="/index/manual" variant="ghost-dark">자세히 보기</LinkButton>
    </div>
  </section>

  <!-- Step 컬럼 -->
  <section class="mx-auto max-w-5xl px-5 py-12 animate-fade-in-up delay-300">
    <div class="grid gap-6 sm:grid-cols-3">
      <div class="flex flex-col gap-3 premium-card rounded-xl border border-line bg-white p-6 shadow-sm justify-between">
        <div>
          <p class="text-[15px] leading-snug text-ink">
            <span class="font-bold text-primary-600">Step 1.</span><br />
            교육디지털원패스 접속 및 회원가입
          </p>
        </div>
        <div class="flex flex-col gap-2 mt-2">
          <LinkButton href="https://edupass.neisplus.kr/" variant="primary" external>
            교육디지털원패스 포털(바로가기)
          </LinkButton>
          <LinkButton href="/index/eduonepass" variant="ghost">도움자료</LinkButton>
        </div>
      </div>

      <div class="flex flex-col gap-3 premium-card rounded-xl border border-line bg-white p-6 shadow-sm justify-between">
        <div>
          <p class="text-[15px] leading-snug text-ink">
            <span class="font-bold text-primary-600">Step 2.</span><br />
            AI·디지털 교육자료 포털에서 수업 진행
          </p>
        </div>
        <div class="flex flex-col gap-2 mt-2">
          <LinkButton href="https://www.aidtbook.kr/" variant="primary" external>
            AI·디지털 교육자료 포털(바로가기)
          </LinkButton>
          <LinkButton href="/class/curriculum" variant="ghost">🔥수업사례 · 설계지원✨</LinkButton>
        </div>
      </div>

      <div class="flex flex-col gap-3 premium-card rounded-xl border border-line bg-white p-6 shadow-sm justify-between">
        <div>
          <p class="text-[15px] leading-snug text-ink">📌자세히 알아보려면(추천자료👍)</p>
        </div>
        <div class="flex flex-col gap-2 mt-2">
          <LinkButton href="/index/manual" variant="ghost">🚩 사전 준비사항 안내✅</LinkButton>
        </div>
      </div>
    </div>
  </section>

  <!-- 다크 밴드 — 문의 안내 -->
  <section class="bg-primary-600 animate-fade-in-up delay-300">
    <div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 px-5 py-6 sm:flex-row">
      <p class="text-[15px] font-semibold text-white sm:text-[16px]">
        AI·디지털 교육자료 사용에 도움이 필요하시다면?
      </p>
      <LinkButton href="/contact" variant="ghost-dark">문의 및 장애 지원</LinkButton>
    </div>
  </section>
</BaseLayout>
