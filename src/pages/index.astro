---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PublisherCard from '../components/PublisherCard.astro';
import LinkButton from '../components/LinkButton.astro';

const publishers = (await getCollection('publishers')).sort(
  (a, b) => a.data.order - b.data.order
);
const featured = publishers.slice(0, 6);

const quickLinks = [
  {
    href: '/index/AIDT',
    title: 'AIDT 시작하기',
    desc: '에듀원패스 로그인부터 첫 수업까지 준비 순서',
    icon: 'M4 5h16M4 12h16M4 19h10',
  },
  {
    href: '/index/feedback',
    title: '출판사별 지원',
    desc: '교과서 출판사별 도움자료·오류 제보 창구',
    icon: 'M3 7l9-4 9 4-9 4-9-4zm0 5l9 4 9-4M3 17l9 4 9-4',
  },
  {
    href: '/class',
    title: '수업이야기',
    desc: '실제 수업 설계·활용 사례와 자료',
    icon: 'M4 4h16v12H5.5L4 18V4z',
  },
  {
    href: '/contact',
    title: '문의·장애 지원',
    desc: '접속·오류 문제를 빠르게 접수',
    icon: 'M12 2a7 7 0 00-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 00-7-7zm0 9a2 2 0 110-4 2 2 0 010 4z',
  },
];
---

<BaseLayout>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="mx-auto max-w-6xl px-5 pb-16 pt-16 sm:pt-24">
      <div class="max-w-3xl">
        <span
          class="reveal inline-flex items-center gap-2 rounded-full border border-primary-200 bg-primary-50 px-3.5 py-1.5 text-[13px] font-semibold text-primary-700"
          style="--d:0ms"
        >
          <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-accent-500"></span>
          대구광역시교육청 · AI 디지털교과서 지원
        </span>

        <h1
          class="reveal mt-6 font-display text-[38px] font-bold leading-[1.15] tracking-tight text-ink sm:text-[54px]"
          style="--d:80ms"
        >
          AI·디지털 교육자료,<br />
          <span class="text-primary-600">수업까지</span> 막힘없이.
        </h1>

        <p
          class="reveal mt-5 max-w-xl text-[17px] leading-relaxed text-muted sm:text-lg"
          style="--d:160ms"
        >
          AI 디지털교과서 수업에 바로 쓰는 도움자료와 출판사별 문의 창구를
          한곳에 모았습니다. 준비 순서대로 따라오면 첫 수업까지 어렵지 않습니다.
        </p>

        <div class="reveal mt-8 flex flex-wrap gap-3" style="--d:240ms">
          <LinkButton href="/index/AIDT" variant="primary">시작 가이드 보기</LinkButton>
          <LinkButton href="/index/feedback" variant="ghost">출판사별 지원</LinkButton>
        </div>
      </div>
    </div>

    <!-- 장식: 부드러운 기하 배경 -->
    <div
      class="pointer-events-none absolute -right-24 -top-24 -z-10 h-96 w-96 rounded-full bg-gradient-to-br from-primary-100/60 to-accent-50/40 blur-3xl"
      aria-hidden="true"
    >
    </div>
  </section>

  <!-- 바로가기 카드 -->
  <section class="mx-auto max-w-6xl px-5">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        quickLinks.map((q, i) => (
          <a
            href={q.href}
            class="reveal group flex flex-col rounded-[var(--radius-card)] border border-line bg-surface p-5 shadow-[var(--shadow-card)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[var(--shadow-card-hover)]"
            style={`--d:${300 + i * 70}ms`}
          >
            <span class="grid h-11 w-11 place-items-center rounded-xl bg-primary-50 text-primary-600 transition-colors group-hover:bg-primary-600 group-hover:text-white">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                <path d={q.icon} stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            <h3 class="mt-4 font-display text-[18px] font-bold text-ink">{q.title}</h3>
            <p class="mt-1 text-[14px] leading-relaxed text-muted">{q.desc}</p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- 출판사별 지원 프리뷰 -->
  <section class="mx-auto max-w-6xl px-5 pt-20">
    <div class="flex items-end justify-between gap-4">
      <SectionHeading eyebrow="Publishers" title="출판사별 지원" />
      <a
        href="/index/feedback"
        class="hidden shrink-0 text-[15px] font-semibold text-primary-700 hover:text-primary-600 sm:block"
      >
        전체 보기 →
      </a>
    </div>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        featured.map((p) => (
          <PublisherCard
            href={`/index/feedback/${p.id}`}
            name={p.data.name}
            subjects={p.data.subjects}
            accent={p.data.accent}
            draft={p.data.draft}
          />
        ))
      }
    </div>

    <div class="mt-8 text-center sm:hidden">
      <LinkButton href="/index/feedback" variant="ghost">출판사 전체 보기</LinkButton>
    </div>
  </section>
</BaseLayout>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(14px);
    animation: reveal 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--d, 0ms);
  }
  @keyframes reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
