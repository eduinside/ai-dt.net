---
/**
 * 홈 — 원본(docs/original/CONTENT.md §2) 문구 유지, 모던 공공 포털 레이아웃.
 * · 히어로: 비대칭 2열 (좌 타이틀 / 우 대표 연락처 카드 — 구 연회색 밴드 흡수)
 * · 절차: 번호 레일(01·02·03) — 구 다크 밴드 문구를 섹션 헤딩으로 흡수
 * · 마무리: 네이비 CTA 패널
 */
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import LinkButton from '../components/LinkButton.astro';
import ReplyBoard from '../components/ReplyBoard.astro';
import { faqRows } from '../data/faq';
import logo from '../assets/logo-512.webp';

const contacts = [
  { label: 'AI·디지털 교육자료 포털', name: '중앙상담센터', tel: '1600-2525' },
  { label: '회원가입 관련', name: '교육디지털원패스', tel: '1600-7440' },
];
---

<BaseLayout>
  <!-- 히어로 — 비대칭 2열, 도트 그리드 캔버스 -->
  <section class="hero-canvas border-b border-line">
    <div
      class="mx-auto grid max-w-6xl items-center gap-10 px-5 pb-14 pt-12 sm:pb-20 sm:pt-16 lg:grid-cols-[1.35fr_1fr] lg:gap-14"
    >
      <div class="animate-fade-in-up">
        <p class="flex items-center gap-2.5 text-[15px] font-semibold tracking-tight text-primary-600">
          <Image src={logo} alt="" width={64} height={64} class="h-9 w-9 shrink-0" loading="eager" />
          대구광역시교육청
        </p>
        <h1
          class="font-display mt-5 text-[34px] font-extrabold leading-[1.16] text-ink sm:text-[52px]"
        >
          AI·디지털 교육자료<br />
          <span class="text-primary-600">수업 지원센터</span>
        </h1>
        <p class="mt-6 max-w-xl text-[16px] leading-relaxed text-muted sm:text-[17.5px]">
          대구광역시교육청이 AI·디지털 교육자료를 손쉽게 활용하여<br class="hidden sm:block" />
          창의적이고 효과적인 수업을 할 수 있도록 지원합니다.
        </p>
      </div>

      <!-- 대표 연락처 — 구 연회색 밴드의 2건을 히어로 우측 카드로 -->
      <div class="flex flex-col gap-4 animate-fade-in-up delay-150">
        {
          contacts.map((c) => (
            <a
              href={`tel:${c.tel}`}
              class="premium-card group flex items-center gap-4 rounded-[var(--radius-card)] border border-line bg-white/90 p-5 shadow-[var(--shadow-card)] backdrop-blur-sm"
            >
              <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-primary-50 text-primary-600 transition-colors group-hover:bg-primary-600 group-hover:text-white">
                <svg width="19" height="19" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path
                    d="M4.2 2.8h3l1.4 3.6-1.9 1.4a11.5 11.5 0 0 0 5.5 5.5l1.4-1.9 3.6 1.4v3a1.6 1.6 0 0 1-1.7 1.6C8.6 16.9 3.1 11.4 2.6 4.5a1.6 1.6 0 0 1 1.6-1.7Z"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
              <span class="min-w-0">
                <span class="block text-[13px] font-medium text-muted">[{c.label}]</span>
                <span class="mt-0.5 block text-[17px] font-bold tracking-tight text-ink">
                  {c.name} <span class="text-primary-600">{c.tel}</span>
                </span>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- FAQ · 도움자료 섹션 -->
  <section class="mx-auto max-w-4xl px-5 pt-14 animate-fade-in-up delay-150">
    <div class="flex items-end justify-between pb-4">
      <h2 class="section-mark text-[20px] font-bold tracking-tight text-ink">선도학교 운영 관련 FAQ</h2>
      <a
        href="/index/faq"
        class="flex items-center gap-1 text-[14px] font-semibold text-primary-600 transition-colors hover:text-primary-700"
      >
        더 보기
        <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="shrink-0">
          <path d="M5 12l5-5-5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>

    <!-- 원본 GAS QnA 게시판을 정적 FAQ 게시판으로 이관 (src/data/faq.ts 공유) -->
    <ReplyBoard rows={faqRows} showPublisher={false} linkToFaq={true} />

    <a
      href="/index/AIDT"
      class="mt-6 flex items-center justify-center gap-2 rounded-xl border border-primary-200 bg-primary-50 py-3.5 text-center text-[15px] font-semibold text-primary-700 transition-all duration-300 hover:border-primary-400 hover:bg-primary-100"
    >
      활용 도움자료 더 보기
      <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M5 12l5-5-5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>
  </section>

  <!-- 절차 안내 — 번호 레일 -->
  <section class="mx-auto max-w-6xl px-5 pb-4 pt-16 animate-fade-in-up delay-200">
    <div class="flex flex-col justify-between gap-3 pb-8 sm:flex-row sm:items-end">
      <h2 class="section-mark max-w-2xl text-[20px] font-bold leading-snug tracking-tight text-ink">
        AI·디지털 교육자료 활용을 위해 필요한 절차를 단계별로 정리해 보았습니다.
      </h2>
      <a
        href="/index/manual"
        class="flex shrink-0 items-center gap-1 text-[14px] font-semibold text-primary-600 transition-colors hover:text-primary-700"
      >
        자세히 보기
        <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="shrink-0">
          <path d="M5 12l5-5-5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>

    <ol class="relative grid gap-6 sm:grid-cols-3">
      <!-- 데스크톱 연결선 -->
      <div
        aria-hidden="true"
        class="absolute left-[8%] right-[8%] top-[2.35rem] hidden h-px bg-[linear-gradient(90deg,transparent,var(--color-line)_15%,var(--color-line)_85%,transparent)] sm:block"
      >
      </div>

      <li
        class="premium-card relative flex flex-col justify-between gap-4 rounded-[var(--radius-card)] border border-line bg-white p-6 pt-5 shadow-[var(--shadow-card)]"
      >
        <div>
          <span
            class="font-display relative z-10 inline-block bg-white pr-3 text-[26px] font-extrabold tracking-tight text-primary-200"
          >
            01
          </span>
          <p class="mt-2 text-[15.5px] font-semibold leading-snug text-ink">
            교육디지털원패스 접속 및 회원가입
          </p>
        </div>
        <div class="flex flex-col gap-2">
          <LinkButton href="https://edupass.neisplus.kr/" variant="primary" external>
            교육디지털원패스 포털(바로가기)
          </LinkButton>
          <LinkButton href="/index/eduonepass" variant="ghost">도움자료</LinkButton>
        </div>
      </li>

      <li
        class="premium-card relative flex flex-col justify-between gap-4 rounded-[var(--radius-card)] border border-line bg-white p-6 pt-5 shadow-[var(--shadow-card)]"
      >
        <div>
          <span
            class="font-display relative z-10 inline-block bg-white pr-3 text-[26px] font-extrabold tracking-tight text-primary-200"
          >
            02
          </span>
          <p class="mt-2 text-[15.5px] font-semibold leading-snug text-ink">
            AI·디지털 교육자료 포털에서 수업 진행
          </p>
        </div>
        <div class="flex flex-col gap-2">
          <LinkButton href="https://www.aidtbook.kr/" variant="primary" external>
            AI·디지털 교육자료 포털(바로가기)
          </LinkButton>
          <LinkButton href="/class/curriculum" variant="ghost">수업사례 · 설계지원</LinkButton>
        </div>
      </li>

      <li
        class="premium-card relative flex flex-col justify-between gap-4 rounded-[var(--radius-card)] border border-primary-200 bg-primary-50/60 p-6 pt-5 shadow-[var(--shadow-card)]"
      >
        <div>
          <span
            class="relative z-10 inline-flex items-center rounded-full bg-[var(--color-accent-soft)] px-2.5 py-1 text-[12px] font-bold tracking-tight text-accent"
          >
            추천자료
          </span>
          <p class="mt-3 text-[15.5px] font-semibold leading-snug text-ink">자세히 알아보려면</p>
        </div>
        <div class="flex flex-col gap-2">
          <LinkButton href="/index/manual" variant="primary">사전 준비사항 안내</LinkButton>
        </div>
      </li>
    </ol>
  </section>

  <!-- 마무리 CTA — 네이비 패널 -->
  <section class="mx-auto max-w-6xl px-5 py-14 animate-fade-in-up delay-300">
    <div
      class="relative overflow-hidden rounded-2xl bg-primary-700 px-6 py-9 sm:px-10"
      style="background-image:
        radial-gradient(560px 280px at 88% -20%, rgba(77, 127, 174, 0.5), transparent 70%),
        radial-gradient(rgba(255, 255, 255, 0.07) 1px, transparent 1px);
      background-size: auto, 20px 20px;"
    >
      <div class="flex flex-col items-start justify-between gap-5 sm:flex-row sm:items-center">
        <p class="text-[18px] font-bold leading-snug tracking-tight text-white sm:text-[21px]">
          AI·디지털 교육자료 사용에<br class="sm:hidden" /> 도움이 필요하시다면?
        </p>
        <a
          href="/contact"
          class="inline-flex shrink-0 items-center gap-2 rounded-xl bg-white px-6 py-3 text-[15px] font-bold text-primary-700 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md"
        >
          문의 및 장애 지원
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M5 12l5-5-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
