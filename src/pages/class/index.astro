---
/**
 * 수업이야기 허브 — 원본(docs/original/CONTENT.md §10).
 * 원본은 배너 이미지 중심이나, 정보 구조(제목·링크)를 카드로 계승.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';

const tutoring = [
  { label: '교사', href: 'https://sites.google.com/dge.go.kr/aidt-tutoring-t/teacher' },
  { label: '학생', href: 'https://sites.google.com/dge.go.kr/aidt-tutoring-t/student' },
  { label: '학교 / 학부모', href: 'https://sites.google.com/dge.go.kr/aidt-tutoring-t/parents' },
];
---

<BaseLayout
  title="수업이야기"
  description="AI·디지털 교육자료를 활용한 수업 사례 — 튜터링 플랫폼, 수업설계 지원, 웹전시관"
>
  <section class="mx-auto max-w-4xl px-5 py-12 sm:py-14">
    <h1 class="title-underline text-center text-[24px] font-bold leading-tight text-ink sm:text-[32px]">
      AI·디지털 교육자료 수업이야기
    </h1>
    <p class="mt-8 text-center text-[16px] text-ink">AI·디지털 교육자료를 활용한 수업 사례를 나눕니다.</p>

    <!-- AI수학 튜터링 -->
    <a
      href="https://sites.google.com/dge.go.kr/aidt-tutoring-t/home"
      target="_blank"
      rel="noopener noreferrer"
      class="mt-10 block rounded-[var(--radius-card)] border border-primary-200 bg-primary-50 p-6 shadow-[var(--shadow-card)] transition-all hover:-translate-y-0.5 hover:shadow-[var(--shadow-card-hover)]"
    >
      <p class="text-[13px] font-bold uppercase tracking-wider text-primary-600">AI수학 디지털 교육자료 튜터링</p>
      <p class="mt-2 text-[18px] font-bold text-ink">미래형 수학 교실을 위한 AI 디지털 교육자료 지원 플랫폼</p>
      <span class="mt-3 inline-flex items-center gap-1 text-[14px] font-semibold text-primary-600">
        바로가기
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M3 11L11 3M5 3h6v6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" /></svg>
      </span>
    </a>

    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      {
        tutoring.map((t) => (
          <a
            href={t.href}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-[var(--radius-card)] border border-line bg-white px-5 py-4 text-center text-[16px] font-bold text-ink shadow-[var(--shadow-card)] transition-colors hover:border-primary-400 hover:text-primary-600"
          >
            {t.label}
          </a>
        ))
      }
    </div>

    <!-- 수업설계 지원 / 웹전시관 -->
    <div class="mt-4 grid gap-3 sm:grid-cols-2">
      <a
        href="/class/curriculum"
        class="rounded-[var(--radius-card)] border border-line bg-white p-6 shadow-[var(--shadow-card)] transition-all hover:-translate-y-0.5 hover:border-primary-400 hover:shadow-[var(--shadow-card-hover)]"
      >
        <p class="text-[18px] font-bold text-ink">수업설계 지원</p>
        <p class="mt-1 text-[14px] text-muted">AI·디지털 교육자료를 활용한 수업설계 도움자료</p>
      </a>
      <a
        href="https://aidtshow.kr/"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-[var(--radius-card)] border border-line bg-white p-6 shadow-[var(--shadow-card)] transition-all hover:-translate-y-0.5 hover:border-primary-400 hover:shadow-[var(--shadow-card-hover)]"
      >
        <p class="text-[18px] font-bold text-ink">AI·디지털 교육자료 웹전시관</p>
        <span class="mt-1 inline-flex items-center gap-1 text-[14px] font-semibold text-primary-600">
          바로가기
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M3 11L11 3M5 3h6v6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </span>
      </a>
    </div>
  </section>
</BaseLayout>
